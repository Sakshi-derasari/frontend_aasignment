# ============================================
# Firebase Configuration
# ============================================
# Firebase project settings → Project Settings → Web API Key
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ============================================
# Spotify API
# ============================================
# Spotify Developer Dashboard → Create App → Client ID / API Key
VITE_SPOTIFY_API_KEY=your_spotify_api_key_here
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id

# ============================================
# Google Maps
# ============================================
# Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# App Settings
# ============================================
VITE_WELCOME_MSG=Hello from environment variables!
VITE_APP_ENV=development
